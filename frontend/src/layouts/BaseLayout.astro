---
import SearchPanel from "../components/SearchPanel.jsx";
import { getNavigationGroups, withBasePath } from "../lib/research.js";
import "../styles/global.css";

const {
  title = "Sonata Research",
  description = "Sonata Research focuses on understanding music",
  currentRoute = "/"
} = Astro.props;

const groups = getNavigationGroups();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
  </head>
  <body>
    <div class="app-shell">
      <aside class="sidebar">
        <details class="sidebar-disclosure" open>
          <summary class="sidebar-toggle">Browse research</summary>
          <div class="sidebar-panel">
            <div class="sidebar-header">
              <a href={withBasePath("/")} class="sidebar-home">Sonata Research</a>
              <p>Sonata Research focuses on understanding music.</p>
            </div>
            <SearchPanel client:load groups={groups} currentRoute={currentRoute} />
          </div>
        </details>
      </aside>
      <main class="main-content">
        <slot />
      </main>
    </div>
  </body>
</html>