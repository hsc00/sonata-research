---
import { marked } from "marked";
import BaseLayout from "../layouts/BaseLayout.astro";
import ArticleNav from "../components/ArticleNav.jsx";
import * as research from "../lib/research.js";

export function getStaticPaths() {
  return research.researchEntries.map((entry) => ({
    params: {
      slug: entry.routeSegments.join("/")
    },
    props: {
      entry
    }
  }));
}

const { entry } = Astro.props;

if (!entry) {
  throw new Error("Research entry not found.");
}

const resolvedEntry = research.findEntryBySlug(entry.routeSegments) ?? entry;
const siblings = research.getSiblingEntries(resolvedEntry);
let headingIndex = 0;

function stripLeadFigure(markdown) {
  return String(markdown || "").replace(/^<figure[\s\S]*?<\/figure>\s*/i, "");
}

function stripMarkdown(text) {
  return String(text || "")
    .replace(/```[\s\S]*?```/g, " ")
    .replace(/`([^`]+)`/g, "$1")
    .replace(/!\[[^\]]*\]\([^)]*\)/g, " ")
    .replace(/\[([^\]]+)\]\(([^)]+)\)/g, "$1")
    .replace(/^>\s?/gm, "")
    .replace(/^#+\s*/gm, "")
    .replace(/^[*-]\s+/gm, "")
    .replace(/\s+/g, " ")
    .trim();
}

function extractLeadParagraph(markdown) {
  const blocks = stripLeadFigure(markdown).split(/\r?\n\r?\n/);

  for (const block of blocks) {
    const trimmed = block.trim();

    if (!trimmed) continue;
    if (trimmed.startsWith("#")) continue;
    if (trimmed.startsWith("<")) continue;
    if (trimmed.startsWith("- ")) continue;

    return stripMarkdown(trimmed);
  }

  return "";
}

function estimateReadingMinutes(markdown) {
  const words = stripMarkdown(stripLeadFigure(markdown)).split(/\s+/).filter(Boolean)
    .length;
  return Math.max(1, Math.round(words / 220));
}

const processedMarkdown = resolvedEntry.markdown.replace(/\[([^\]]+)\]\(([^)]+)\)/g, (m, text, href) => {
  try {
    const mapped = research.resolveMarkdownHref(href, resolvedEntry.sourcePath) || href;
    return `[${text}](${mapped})`;
  } catch (e) {
    return m;
  }
});

const html = marked.parse(processedMarkdown).replace(/<h([2-6])>(.*?)<\/h\1>/g, (match, depth) => {
  const heading = resolvedEntry.headings[headingIndex];

  if (!heading || heading.depth !== Number(depth)) {
    return match;
  }

  headingIndex += 1;
  return `<h${depth} id="${heading.slug}">${heading.text}</h${depth}>`;
});
const sectionLabel = research.getSectionLabel(resolvedEntry.section);
const leadParagraph = extractLeadParagraph(resolvedEntry.markdown);
const readingMinutes = estimateReadingMinutes(resolvedEntry.markdown);
const keySections = resolvedEntry.headings
  .filter((heading) => heading.depth === 2 && heading.text !== "Sources")
  .slice(0, 5);
---

<BaseLayout title={`${resolvedEntry.title} | Sonata Research`} currentRoute={resolvedEntry.route}>
  <header class="article-header">
    <p class="eyebrow">{sectionLabel}</p>
    <h1>{resolvedEntry.title}</h1>
    <div class="article-meta">
      <span>{resolvedEntry.sourcePath.replace(/\.md$/i, "")}</span>
      <span>{resolvedEntry.headings.length} subsections</span>
      <span>{readingMinutes} min read</span>
    </div>
  </header>

  <section class="article-glance">
    <div class="glance-card glance-lead">
      <p class="eyebrow">At A Glance</p>
      <p>{leadParagraph}</p>
    </div>

    <div class="glance-card">
      <p class="eyebrow">Quick Map</p>
      <ul class="glance-list">
        {keySections.map((heading) => (
          <li>
            <a href={`#${heading.slug}`}>{heading.text}</a>
          </li>
        ))}
      </ul>
    </div>

    <div class="glance-card glance-stats">
      <p class="eyebrow">Reading Shape</p>
      <dl>
        <div>
          <dt>Read time</dt>
          <dd>{readingMinutes} min</dd>
        </div>
        <div>
          <dt>Main sections</dt>
          <dd>{keySections.length}</dd>
        </div>
        <div>
          <dt>Total subsections</dt>
          <dd>{resolvedEntry.headings.length}</dd>
        </div>
      </dl>
    </div>
  </section>

  <div class="article-shell">
    <article class="article-body" set:html={html} />

    <aside class="article-aside">
      <ArticleNav client:load headings={resolvedEntry.headings} />

      <section class="toc-block">
        <h2>Within {sectionLabel}</h2>
        <div class="sibling-links">
          {siblings.previous ? <a href={research.withBasePath(siblings.previous.route)}>Previous: {siblings.previous.title}</a> : <span />}
          {siblings.next ? <a href={research.withBasePath(siblings.next.route)}>Next: {siblings.next.title}</a> : <span />}
        </div>
      </section>
    </aside>
  </div>
</BaseLayout>